{
  "name": "temp-mail",
  "version": "1.0.0",
  "description": "Geçici e-posta web uygulaması - kendi domainleriniz üzerinden geçici adresler oluşturun",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "NODE_ENV=production node server/index.js",
    "install:all": "npm install && cd client && npm install",
    "setup": "cp .env.example .env && npm run install:all"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mailparser": "^3.7.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "smtp-server": "^3.13.0",
    "socket.io": "^4.8.3",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
