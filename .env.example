# === Temp Mail Uygulaması Yapılandırma ===

# API sunucu portu (Express)
API_PORT=3001

# SMTP sunucu portu (gelen mailler için)
# Port 25 için root/yetkili erişim gerekir
# Geliştirme amaçlı 1025 kullanabilirsiniz
SMTP_PORT=25

# Admin paneli şifresi
ADMIN_PASSWORD=admin123

# Geçici adreslerin yaşam süresi (dakika)
ADDRESS_TTL_MINUTES=60

# Node ortamı (development / production)
NODE_ENV=development

# === Webhook Desteği ===
# Gelen her mail için bu URL'e POST isteği atılır
# Boş bırakırsanız webhook devre dışı kalır
WEBHOOK_URL=

# === Mail Gönderme (SMTP Relay) ===
# Giden mailler için SMTP sunucu ayarları
# Boş bırakırsanız mail gönderme devre dışı kalır
# Gmail örneği: smtp.gmail.com / 587 / true
# SendGrid örneği: smtp.sendgrid.net / 587 / false
SMTP_RELAY_HOST=
SMTP_RELAY_PORT=587
SMTP_RELAY_SECURE=false
SMTP_RELAY_USER=
SMTP_RELAY_PASS=
